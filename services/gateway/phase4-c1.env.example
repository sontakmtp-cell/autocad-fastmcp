# Non-secret template only. Store real values in the VPS secret manager/service environment.
AUTOCAD_MCP_GATEWAY_PROFILE=phase4_c1
AUTOCAD_MCP_PUBLIC_V1_HOST=127.0.0.1
AUTOCAD_MCP_PUBLIC_V1_PORT=8765
AUTOCAD_MCP_PUBLIC_V1_PATH=/mcp
AUTOCAD_MCP_PUBLIC_V1_STATELESS_HTTP=1
AUTOCAD_MCP_PUBLIC_V1_ALLOWED_HOSTS=cad.example.com
AUTOCAD_MCP_PUBLIC_V1_ALLOWED_ORIGINS=https://approved-client.example

AUTOCAD_MCP_PHASE4_DB_PATH=/var/lib/autocad-mcp/phase4-c1.db
AUTOCAD_MCP_PHASE4_DEVICE_ID=device-lab
AUTOCAD_MCP_PHASE4_DEVICE_CREDENTIAL=replace-in-secret-manager
AUTOCAD_MCP_PHASE4_OWNER_SUBJECT=auth0|replace-with-lab-subject
AUTOCAD_MCP_PHASE4_DEVICE_DISPLAY_NAME=Máy AutoCAD Lab
AUTOCAD_MCP_PHASE4_WRITE_DISABLED=1

AUTOCAD_MCP_PHASE4_OAUTH_ISSUER=https://tenant.example.com/
AUTOCAD_MCP_PHASE4_OAUTH_AUDIENCE=https://cad.example.com
AUTOCAD_MCP_PHASE4_OAUTH_JWKS_URI=https://tenant.example.com/.well-known/jwks.json
AUTOCAD_MCP_PHASE4_PUBLIC_ORIGIN=https://cad.example.com

AUTOCAD_MCP_PHASE4_PACKAGE_ID=autocad.lisp.drawing_info
AUTOCAD_MCP_PHASE4_PACKAGE_VERSION=3.3-c1
AUTOCAD_MCP_PHASE4_PACKAGE_SHA256=replace-with-64-lowercase-hex
